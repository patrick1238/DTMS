      <Button fx:id="RegisterButton" layoutX="90.0" layoutY="94.0" mnemonicParsing="false" onAction="#RegisterButtonPressed" prefHeight="26.0" prefWidth="90.0" text="Register" AnchorPane.bottomAnchor="11.0" AnchorPane.rightAnchor="112.0" />
      <Label layoutX="14.0" layoutY="22.0" text="User:" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="22.0" />
      <Label layoutX="13.0" layoutY="64.0" text="Password:" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="65.0" />
      <ComboBox fx:id="RegisterBox" editable="true" layoutX="74.0" layoutY="18.0" prefWidth="150.0" promptText="Enter username" AnchorPane.leftAnchor="90.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="18.0" />
      <PasswordField fx:id="PasswordField" layoutX="93.0" layoutY="60.0" prefHeight="26.0" prefWidth="141.0" promptText="Enter password" AnchorPane.leftAnchor="90.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="60.0" />
   </children>
