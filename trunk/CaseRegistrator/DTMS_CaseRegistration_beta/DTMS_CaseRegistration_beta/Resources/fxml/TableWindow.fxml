<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane id="mainWindow" fx:id="mainWindow" prefHeight="535.0" prefWidth="729.0" xmlns="http://javafx.com/javafx/9.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Windowcontroller.TableWindowController">
    <children>
      <Label fx:id="ImageCounterLabel" alignment="CENTER" layoutX="15.0" layoutY="14.0" prefHeight="18.0" prefWidth="300.0" text="Cases added: $$$, Files added:  $$$" textAlignment="CENTER" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="13.0" AnchorPane.topAnchor="14.0" />
      <HBox fx:id="TableBox" layoutY="85.0" prefHeight="405.0" prefWidth="701.0" spacing="10.0" AnchorPane.bottomAnchor="45.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="13.0" AnchorPane.topAnchor="85.0">
         <children>
            <TableView fx:id="CaseTable" prefHeight="360.0" prefWidth="702.0" HBox.hgrow="SOMETIMES">
              <columns>
                <TableColumn prefWidth="75.0" text="C1" />
                <TableColumn prefWidth="75.0" text="C2" />
              </columns>
            </TableView>
         </children>
      </HBox>
      <Button fx:id="addCaseButton" layoutX="15.0" layoutY="44.0" mnemonicParsing="false" onAction="#addCaseClicked" prefHeight="26.0" prefWidth="701.0" text="Add Case" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="44.0" />
      <Button fx:id="saveButton" alignment="CENTER" contentDisplay="CENTER" layoutX="15.0" layoutY="489.0" mnemonicParsing="false" onAction="#saveClicked" prefHeight="26.0" prefWidth="701.0" text="Save" textAlignment="CENTER" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" />
    </children>
</AnchorPane>
